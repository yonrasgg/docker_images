# =============================================================================
# .dockerignore — Whitelist approach (deny-all, allow only what builds need)
# This is the safest strategy: nothing enters the build context unless
# explicitly permitted. Prevents accidental exfiltration of secrets,
# credentials, CI config, or repository metadata into image layers.
# =============================================================================

# ---- DENY EVERYTHING ----
*

# ---- ALLOW: Build-required files only ----
# shared/hardening.sh — copied by all Dockerfiles
# shared/strip.sh    — final stripping, runs after user creation
!shared/
!shared/hardening.sh
!shared/strip.sh

# Sonarr
!sonarr/
!sonarr/Dockerfile
!sonarr/entrypoint.sh

# Radarr
!radarr/
!radarr/Dockerfile
!radarr/entrypoint.sh

# SABnzbd
!sabnzbd/
!sabnzbd/Dockerfile
!sabnzbd/entrypoint.sh

# Jackett
!jackett/
!jackett/Dockerfile
!jackett/entrypoint.sh

# Plex
!plex/
!plex/Dockerfile
!plex/entrypoint.sh

# Dashy
!dashy/
!dashy/Dockerfile
!dashy/entrypoint.sh

# ---- DENY: Anything that sneaks into allowed directories ----
# Even inside allowed dirs, block sensitive patterns as defense-in-depth
**/.env
**/.env.*
**/*.key
**/*.pem
**/*.cer
**/*.crt
**/*.p12
**/*.pfx
**/*.jks
**/*.sig
**/*.gpg
**/*.asc
**/*.password
**/*.passwd
**/.git
**/.gitignore
**/*.md
**/*.log
**/*.db
**/*.sqlite*
**/__pycache__/
**/*.pyc
**/*.tar
**/*.tar.gz
**/*.sarif
**/sbom-*
**/secrets/
**/credentials/
**/private/
**/.docker/
**/.aws/
**/.azure/
**/.gcp/
**/.kube/
**/config.xml
**/*.ini
**/Preferences.xml
